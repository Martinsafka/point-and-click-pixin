  "dialogs": {
    "keeper": {
      "start": "root",
      "nodes": {
        "root": {
          "branch": [
            {
              "when": {
                "kind": "flag",
                "flag": "rats-cleared"
              },
              "to": "free"
            },
            {
              "when": {
                "kind": "flag",
                "flag": "keeper-deal"
              },
              "to": "nag"
            }
          ],
          "next": "offer"
        },
        "offer": {
          "speaker": "keeper",
          "text": "Á, nová tvář. Poslyš, trhane - mám ve sklepě krysy. Vyžeň je a piva ti naleju, kolik uneseš.",
          "choices": [
            {
              "text": "Beru ten kšeft.",
              "effects": [
                {
                  "kind": "setFlag",
                  "flag": "keeper-deal"
                }
              ],
              "next": "dealdone"
            },
            {
              "text": "A pivo hned, zadarmo?",
              "next": "nochance"
            },
            {
              "text": "Zatím ne."
            }
          ]
        },
        "dealdone": {
          "speaker": "keeper",
          "text": "Platí. Sklep je tamhle pod poklopem. Žádné krysy - a teče pivo."
        },
        "nochance": {
          "speaker": "keeper",
          "text": "Zadarmo? Cha! Na pivo si tady musíš zasloužit, chlapče.",
          "next": "offer"
        },
        "nag": {
          "speaker": "keeper",
          "text": "Pořád ty krysy slyším cupitat. Žádné krysy - žádné pivo."
        },
        "free": {
          "branch": [
            {
              "when": {
                "kind": "hasItem",
                "item": "beer"
              },
              "to": "hasbeer"
            },
            {
              "when": {
                "kind": "flag",
                "flag": "got-first-beer"
              },
              "to": "more"
            }
          ],
          "speaker": "keeper",
          "text": "Sklep je čistý! Tu máš, na účet podniku. ...A někdo tam u poklopu nechal rybářský splávek, co? Cha.",
          "effects": [
            {
              "kind": "giveItem",
              "item": "beer"
            },
            {
              "kind": "setFlag",
              "flag": "got-first-beer"
            }
          ]
        },
        "more": {
          "speaker": "keeper",
          "text": "Další pivo? Drž. Ale pomalu, chlapče.",
          "effects": [
            {
              "kind": "giveItem",
              "item": "beer"
            }
          ]
        },
        "hasbeer": {
          "speaker": "keeper",
          "text": "Nejdřív dopij, co máš v ruce. Jedno po druhém."
        }
      }
    },
    "vendor": {
      "start": "root",
      "nodes": {
        "root": {
          "branch": [
            {
              "when": {
                "kind": "hasItem",
                "item": "charm"
              },
              "to": "trade"
            },
            {
              "when": {
                "kind": "flag",
                "flag": "traded-fish"
              },
              "to": "done"
            }
          ],
          "next": "lament"
        },
        "lament": {
          "speaker": "vendor",
          "text": "Ach jo. Ztratila jsem svůj amulet pro štěstí - spadl mi do té mříže v uličce. Bez něj mi ryby na udici nejdou.",
          "choices": [
            {
              "text": "Mrknu po něm."
            },
            {
              "text": "Nemáš rybu nazbyt?",
              "next": "norfree"
            }
          ]
        },
        "norfree": {
          "speaker": "vendor",
          "text": "Rybu jen tak? Přines mi ten amulet a dostaneš tu nejtučnější, co mám!"
        },
        "trade": {
          "speaker": "vendor",
          "text": "Můj amulet! Tys ho našel! Ty jsi učiněný anděl, trhane. Na - vem si tu nejlepší rybu!",
          "effects": [
            {
              "kind": "takeItem",
              "item": "charm"
            },
            {
              "kind": "giveItem",
              "item": "fish"
            },
            {
              "kind": "setFlag",
              "flag": "traded-fish"
            }
          ]
        },
        "done": {
          "speaker": "vendor",
          "text": "Díky tobě zas loví jako za mlada. Víc ryb nazbyt nemám, promiň."
        }
      }
    },
    "onion-seller": {
      "start": "root",
      "nodes": {
        "root": {
          "branch": [
            {
              "when": {
                "kind": "hasItem",
                "item": "onion"
              },
              "to": "hasonion"
            }
          ],
          "next": "sell"
        },
        "sell": {
          "speaker": "onion",
          "text": "Cibule! Krásná cibule! Ty vypadáš jako chlap, co potřebuje cibuli. První je zadarmo - stejně ji nikdo nechce.",
          "choices": [
            {
              "text": "Beru cibuli.",
              "effects": [
                {
                  "kind": "giveItem",
                  "item": "onion"
                }
              ],
              "next": "took"
            },
            {
              "text": "Na co mi je cibule?",
              "next": "why"
            },
            {
              "text": "Dík, nechci."
            }
          ]
        },
        "took": {
          "speaker": "onion",
          "text": "Moudrá volba! Cibule vyřeší skoro všechno."
        },
        "why": {
          "speaker": "onion",
          "text": "Na co? Na guláš, na pláč, na zahnání upírů... a kdo ví, na co ještě.",
          "next": "sell"
        },
        "hasonion": {
          "speaker": "onion",
          "text": "Cibuli už máš. Víc než jednu cibuli člověk nepotřebuje, věř starému cibuláři."
        }
      }
    },
    "guard": {
