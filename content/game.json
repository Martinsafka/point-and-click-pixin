    "intro-line": {
      "start": "a",
      "nodes": {
        "a": {
          "speaker": "Vypravěč",
          "text": "Byl jednou jeden trhan. Bez koruny, bez domova - a hlavně bez piva.",
          "next": "b"
        },
        "b": {
          "speaker": "Claude",
          "text": "*škytne* Jmenuju se Claude. A propil jsem úplně všecko. I boty.",
