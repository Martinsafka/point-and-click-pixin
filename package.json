{
  "name": "@theideaguards/pixin",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.3",
  "description": "A data-driven point-and-click adventure engine + no-code visual editor (PixiJS v8).",
  "license": "MIT",
  "author": "Martin Šafka",
  "homepage": "https://martinsafka.github.io/point-and-click-pixin/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Martinsafka/point-and-click-pixin.git"
  },
  "bugs": {
    "url": "https://github.com/Martinsafka/point-and-click-pixin/issues"
  },
  "keywords": [
    "point-and-click",
    "adventure",
    "game-engine",
    "pixijs",
    "editor",
    "no-code",
    "react"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.js"
    },
    "./editor": {
      "types": "./dist-lib/editor-entry.d.ts",
      "import": "./dist-lib/editor.js"
    },
    "./styles.css": "./dist-lib/pixin.css"
  },
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "files": [
    "dist-lib"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "pnpm build && node scripts/assemble-site.mjs",
    "build:lib": "vite build --config vite.lib.config.ts",
    "prepublishOnly": "pnpm build:lib",
    "assets": "node scripts/build-assets.mjs",
    "preview": "vite preview",
    "preview:site": "node scripts/preview-site.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "earcut": "^3.0.2",
    "howler": "^2.2.4",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "pixi.js": "^8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@xyflow/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/earcut": "^3.0.0",
    "@types/howler": "^2.2.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.11.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "pixi.js": "^8.19.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.3"
  }
}
